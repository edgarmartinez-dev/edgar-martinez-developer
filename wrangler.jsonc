{
  "name": "portfolio",
  "compatibility_date": "2026-07-16",
  "main": "./worker/index.js",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS",
    "run_worker_first": ["/apps/*"]
  },
  "services": [{ "binding": "NDEALS", "service": "ndeals" }]
}
